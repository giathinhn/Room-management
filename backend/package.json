  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "@prisma/client": "^5.22.0",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "prisma": "^5.22.0",
    "nodemon": "^3.1.7",
    "eslint": "^8.57.1",
    "prettier": "^3.3.3"
  }
}
